{
  "name": "numetric-web",
  "private": true,
  "version": "0.1.1",
  "description": "Numetric — AI math tutor for gateway college courses (Algebra, Precalculus, Calculus I)",
  "scripts": {
    "// --- Dev & Build ---": "",
    "dev": "next dev --turbo -p 3000",
    "dev:webpack": "NEXT_DISABLE_TURBO=1 next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",

    "// --- Prisma & Database ---": "",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:reset": "prisma migrate reset --force",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "tsx -r tsconfig-paths/register prisma/seed.ts",
    "prisma:seed": "pnpm db:seed",
    "db:sync": "pnpm db:push && pnpm prisma:generate && pnpm db:seed",

    "// --- Utils ---": "",
    "kill:3000": "npx kill-port 3000 || true",
    "check:env": "grep DATABASE_URL .env || echo 'DATABASE_URL not set'",
    "clean": "rm -rf .next node_modules && pnpm install"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.32.0",
    "@prisma/client": "^6.16.2",
    "autoprefixer": "10.4.18",
    "katex": "0.16.11",
    "mathlive": "0.107.0",
    "next": "15.5.3",
    "postcss": "8.4.35",
    "posthog-js": "^1.266.0",
    "prisma": "^6.16.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "8.0.7",
    "rehype-katex": "6.0.3",
    "remark-math": "5.1.1",
    "sharp": "^0.34.4",
    "stripe": "^18.5.0",
    "tailwindcss": "3.4.7",
    "tesseract.js": "^6.0.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/katex": "^0.16.7",
    "@types/node": "20.12.12",
    "@types/react": "18.2.43",
    "@types/react-dom": "18.2.17",
    "@types/stripe": "^8.0.417",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.5",
    "typescript": "5.4.5"
  }
}
